# Gerçek adaptör yerine sahte (mock) veri kullanılsın mı?
OBD_MOCK_MODE=true

# Gerçek modda kullanılacak seri port (örn. /dev/tty.OBDII veya COM5). Boş bırakılırsa otomatik taranır.
OBD_ADAPTER_PORT=

# Anthropic API anahtarı — asla kod içine gömmeyin, buraya gerçek anahtarı yazmayın.
ANTHROPIC_API_KEY=

# Kullanılacak Claude modeli
ANTHROPIC_MODEL=claude-opus-4-8

# SQLite veritabanı dosya yolu (geçmiş veri kaydı için)
DATABASE_PATH=data/history.db

# Frontend'in çalıştığı origin(ler), virgülle ayrılmış
# Not: Vite 5173 doluysa otomatik olarak 5174'e (veya sıradaki boş porta) geçer.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
